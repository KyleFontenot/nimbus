{
	"name": "@kfontenot/nimbus",
	"version": "0.6.0",
	"description": "A vanilla CSS Svelte 5 Component library",
	"type": "module",
	"license": "GNU GPLv3",
	"private": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"svelte": "./dist/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./components/*": {
			"types": "./dist/components/*.svelte.d.ts",
			"svelte": "./dist/components/*.svelte",
			"default": "./dist/components/*.svelte"
		},
		"./layouts/*": {
			"types": "./dist/layouts/*.svelte.d.ts",
			"svelte": "./dist/layouts/*.svelte",
			"default": "./dist/layouts/*.svelte"
		},
		"./clumps/*": {
			"types": "./dist/clumps/*.svelte.d.ts",
			"svelte": "./dist/clumps/*.svelte",
			"default": "./dist/clumps/*.svelte"
		},
		"./styles/*": "./dist/style/*",
		"./utils/*": {
			"types": "./dist/utils/*.d.ts",
			"default": "./dist/utils/*.js"
		}
	},
	"files": ["dist"],
	"scripts": {
		"build": "svelte-package -i src -o dist",
		"lint": "biome check .",
		"format": "biome format .",
		"check": "biome check .",
		"prepublishOnly": "npm run build"
	},
	"homepage": "https://github.com/KyleFontenot/nimbus#readme",
	"publishConfig": {
		"access": "public"
	},
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@sveltejs/package": "^2.3.0",
		"@sveltejs/vite-plugin-svelte": "^5.0.0",
		"svelte": "^5.0.0",
		"typescript": "^5.5.0"
	},
	"dependencies": {
		"highlight.js": "^11.11.0"
	}
}
