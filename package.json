{
	"name": "nimbus",
	"version": "0.5.2",
	"description": "A non-tailwind Svelte 5 Component library meant for simplistic handling and high-level styling.",
	"type": "module",
	"license": "GNU GPLv3",
	"private": false,
	"main": "dist/index.js",
	"module": "dist/index.js",
	"types": "dist/index.d.ts",
	"svelte": "src/index.js",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"svelte": "./src/index.js",
			"default": "./dist/index.js"
		},
		"./components/*": {
			"types": "./dist/components/*.d.ts",
			"svelte": "./src/components/*.svelte",
			"default": "./dist/components/*.js"
		},
		"./layouts/*": {
			"types": "./dist/layouts/*.d.ts",
			"svelte": "./src/layouts/*.svelte",
			"default": "./dist/layouts/*.js"
		},
		"./clumps/*": {
			"types": "./dist/clumps/*.d.ts",
			"svelte": "./src/clumps/*.svelte",
			"default": "./dist/clumps/*.js"
		},
		"./styles/*": "./dist/styles/*",
		"./utils/*": {
			"types": "./dist/utils/*.d.ts",
			"default": "./dist/utils/*.js"
		}
	},
	"files": ["dist", "src"],
	"scripts": {
		"build": "bun run ./build.ts",
		"lint": "biome check .",
		"format": "biome format .",
		"check": "biome check .",
		"prepublishOnly": "npm run build"
	},
	"homepage": "https://github.com/KyleFontenot/nimbus#readme",
	"peerDependencies": {
		"svelte": "^5.0.0"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9.4",
		"@sveltejs/kit": "^2.16.1",
		"@types/bun": "^1.2.0",
		"@typescript-eslint/eslint-plugin": "^4.22.0",
		"@typescript-eslint/parser": "^4.22.0",
		"typescript": "^5.5.0"
	},
	"dependencies": {
		"highlight.js": "^11.11.0"
	}
}
